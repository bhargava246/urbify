// ─────────────────────────────────────────────────────────────────────────────
// PropEase – Prisma Schema  |  MongoDB  |  Version 1.0
// ─────────────────────────────────────────────────────────────────────────────

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mongodb"
  url      = env("DATABASE_URL")
}

// ─── Enums ───────────────────────────────────────────────────────────────────

enum Role {
  OWNER
  BROKER
  CLIENT
  ADMIN
}

enum ListingType {
  RESIDENTIAL_RENTAL
  COMMERCIAL_RENTAL
  RESIDENTIAL_SALE
  COMMERCIAL_SALE
  LAND
}

enum ListingStatus {
  DRAFT
  PENDING_REVIEW
  ACTIVE
  PAUSED
  RENTED_SOLD
  EXPIRED
  REJECTED
}

enum FurnishingStatus {
  UNFURNISHED
  SEMI_FURNISHED
  FULLY_FURNISHED
}

enum PropertyFacing {
  NORTH
  SOUTH
  EAST
  WEST
  NORTH_EAST
  NORTH_WEST
  SOUTH_EAST
  SOUTH_WEST
}

enum UnlockStatus {
  PENDING
  SUCCESS
  FAILED
  REFUNDED
}

enum NotificationType {
  LISTING_LIVE
  LISTING_EXPIRING
  LISTING_UNLOCKED
  SEARCH_MATCH
  REFUND_PROCESSED
  COMMISSION_CREDITED
  LISTING_RENTED_SOLD
  SYSTEM
}

enum NotificationChannel {
  IN_APP
  EMAIL
  SMS
  PUSH
}

// ─── User ─────────────────────────────────────────────────────────────────────

model User {
  id              String    @id @default(auto()) @map("_id") @db.ObjectId
  email           String?   @unique
  phone           String?   @unique
  passwordHash    String?
  role            Role      @default(CLIENT)
  isVerified      Boolean   @default(false)
  isActive        Boolean   @default(true)
  isBanned        Boolean   @default(false)
  trustBadge      Boolean   @default(false)   // Aadhaar-linked owners
  refreshToken    String?
  otpCode         String?
  otpExpiresAt    DateTime?
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  ownerProfile    OwnerProfile?
  brokerProfile   BrokerProfile?
  clientProfile   ClientProfile?
  listings        Listing[]
  unlocks         ContactUnlock[]
  savedSearches   SavedSearch[]
  shortlists      Shortlist[]
  notifications   Notification[]
  reviews         Review[]

  @@index([role])
  @@map("users")
}

model OwnerProfile {
  id            String   @id @default(auto()) @map("_id") @db.ObjectId
  userId        String   @unique @db.ObjectId
  fullName      String
  aadhaarLinked Boolean  @default(false)
  city          String
  state         String
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  user          User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("owner_profiles")
}

model BrokerProfile {
  id            String   @id @default(auto()) @map("_id") @db.ObjectId
  userId        String   @unique @db.ObjectId
  fullName      String
  reraId        String?
  city          String
  state         String
  isReraVerified Boolean @default(false)
  totalListings  Int     @default(0)
  totalUnlocks   Int     @default(0)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  user          User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("broker_profiles")
}

model ClientProfile {
  id              String   @id @default(auto()) @map("_id") @db.ObjectId
  userId          String   @unique @db.ObjectId
  fullName        String
  employmentType  String?
  incomeRange     String?
  city            String?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  user            User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("client_profiles")
}

// ─── Listing ─────────────────────────────────────────────────────────────────

model Listing {
  id                String           @id @default(auto()) @map("_id") @db.ObjectId
  ownerId           String           @db.ObjectId
  listingType       ListingType
  status            ListingStatus    @default(DRAFT)

  // Location
  locality          String           // shown publicly
  landmark          String?
  city              String
  state             String
  pincode           String
  encryptedAddress  String           // AES-256 encrypted full address
  latitude          Float?
  longitude         Float?
  // GeoJSON Point for $near / 2dsphere queries
  // Set automatically by the service when lat/lng are provided
  geoLocation       Json?   // { type: "Point", coordinates: [lng, lat] }

  // Property Details
  title             String
  description       String
  propertySubType   String           // e.g., "apartment", "independent_house", "pg", "office"
  bhk               Int?             // null for commercial/land
  areaSqFt          Float
  floor             Int?
  totalFloors       Int?
  facing            PropertyFacing?
  propertyAge       Int?             // in years
  furnishingStatus  FurnishingStatus?

  // Pricing
  rentOrPrice       Float            // monthly rent OR sale price
  securityDeposit   Float?
  maintenanceCharge Float?

  // Availability
  availableFrom     DateTime
  isNegotiable      Boolean          @default(false)

  // Media
  photos            ListingPhoto[]
  videoUrl          String?

  // Metadata
  isBrokerListing   Boolean          @default(false)
  isBoostActive     Boolean          @default(false)
  boostExpiresAt    DateTime?
  viewCount         Int              @default(0)
  unlockCount       Int              @default(0)
  expiresAt         DateTime
  moderationNote    String?
  rejectionReason   String?

  createdAt         DateTime         @default(now())
  updatedAt         DateTime         @updatedAt

  owner             User             @relation(fields: [ownerId], references: [id])
  amenities         ListingAmenity[]
  unlocks           ContactUnlock[]
  shortlists        Shortlist[]

  @@index([city, listingType, status])
  @@index([locality])
  // 2dsphere index created directly on MongoDB — see scripts/create-geo-index.js
  @@index([rentOrPrice])
  @@index([status])
  @@index([bhk])
  @@index([createdAt])
  @@map("listings")
}

model ListingPhoto {
  id         String   @id @default(auto()) @map("_id") @db.ObjectId
  listingId  String   @db.ObjectId
  s3Key      String
  s3Url      String
  order      Int      @default(0)
  isPrimary  Boolean  @default(false)
  createdAt  DateTime @default(now())

  listing    Listing  @relation(fields: [listingId], references: [id], onDelete: Cascade)

  @@map("listing_photos")
}

model ListingAmenity {
  id        String   @id @default(auto()) @map("_id") @db.ObjectId
  listingId String   @db.ObjectId
  name      String

  listing   Listing  @relation(fields: [listingId], references: [id], onDelete: Cascade)

  @@map("listing_amenities")
}

// ─── Contact Unlock & Payment ─────────────────────────────────────────────────

model ContactUnlock {
  id                String       @id @default(auto()) @map("_id") @db.ObjectId
  clientId          String       @db.ObjectId
  listingId         String       @db.ObjectId
  platformFeeInr    Float
  gstAmount         Float
  totalAmountInr    Float
  status            UnlockStatus @default(PENDING)

  // Payment gateway (PhonePe)
  merchantTransactionId String?  @unique  // our generated txn ID sent to PhonePe
  phonePeTransactionId  String?            // PhonePe's own transaction reference

  // Invoice
  invoiceNumber     String?      @unique
  invoiceS3Key      String?

  refundReason      String?
  refundedAt        DateTime?
  expiresAt         DateTime?    // 24-hour window for refund claim

  createdAt         DateTime     @default(now())
  updatedAt         DateTime     @updatedAt

  client            User         @relation(fields: [clientId], references: [id])
  listing           Listing      @relation(fields: [listingId], references: [id])

  @@unique([clientId, listingId])  // prevent duplicate unlock
  @@index([clientId])
  @@index([listingId])
  @@index([status])
  @@map("contact_unlocks")
}

// ─── Saved Search ─────────────────────────────────────────────────────────────

model SavedSearch {
  id          String   @id @default(auto()) @map("_id") @db.ObjectId
  userId      String   @db.ObjectId
  name        String?
  filters     Json     // flexible filter criteria blob
  isActive    Boolean  @default(true)
  lastAlertAt DateTime?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("saved_searches")
}

// ─── Shortlist ────────────────────────────────────────────────────────────────

model Shortlist {
  id        String   @id @default(auto()) @map("_id") @db.ObjectId
  userId    String   @db.ObjectId
  listingId String   @db.ObjectId
  createdAt DateTime @default(now())

  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  listing   Listing  @relation(fields: [listingId], references: [id], onDelete: Cascade)

  @@unique([userId, listingId])
  @@map("shortlists")
}

// ─── Notification ─────────────────────────────────────────────────────────────

model Notification {
  id        String              @id @default(auto()) @map("_id") @db.ObjectId
  userId    String              @db.ObjectId
  type      NotificationType
  channel   NotificationChannel
  title     String
  body      String
  isRead    Boolean             @default(false)
  metadata  Json?
  createdAt DateTime            @default(now())

  user      User                @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, isRead])
  @@map("notifications")
}

// ─── Review ───────────────────────────────────────────────────────────────────

model Review {
  id        String   @id @default(auto()) @map("_id") @db.ObjectId
  userId    String   @db.ObjectId
  targetId  String   @db.ObjectId  // could be a listing or user
  targetType String                // "LISTING" | "USER"
  rating    Int
  comment   String?
  createdAt DateTime @default(now())

  user      User     @relation(fields: [userId], references: [id])

  @@index([targetId, targetType])
  @@map("reviews")
}

// ─── CMS / Blog ───────────────────────────────────────────────────────────────

model BlogPost {
  id          String   @id @default(auto()) @map("_id") @db.ObjectId
  slug        String   @unique
  title       String
  excerpt     String
  content     String
  authorName  String
  tags        String[]
  category    String
  isPublished Boolean  @default(false)
  publishedAt DateTime?
  metaTitle   String?
  metaDesc    String?
  featuredImageS3Key String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([isPublished])
  @@map("blog_posts")
}

model LocalityPage {
  id          String   @id @default(auto()) @map("_id") @db.ObjectId
  city        String
  locality    String
  slug        String   @unique
  description String
  avgRent     Float?
  metaTitle   String?
  metaDesc    String?
  isPublished Boolean  @default(false)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@unique([city, locality])
  @@map("locality_pages")
}
