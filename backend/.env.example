# ─────────────────────────────────────────────────────────
# PropEase Backend – Environment Variables
# Copy to .env and fill in your values
# ─────────────────────────────────────────────────────────

# App
NODE_ENV=development
PORT=3001
API_PREFIX=api/v1
FRONTEND_URL=http://localhost:3000

# MongoDB (Atlas or self-hosted)
DATABASE_URL="mongodb+srv://<user>:<password>@cluster.mongodb.net/propease?retryWrites=true&w=majority"

# JWT
JWT_ACCESS_SECRET=your_access_secret_min_32_chars
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_SECRET=your_refresh_secret_min_32_chars
JWT_REFRESH_EXPIRES_IN=7d

# AES encryption (for storing full addresses)
ENCRYPTION_KEY=32_char_hex_encryption_key_here!

# AWS S3 (file uploads only — SES/SNS not used)
AWS_REGION=ap-south-1
AWS_ACCESS_KEY_ID=AKIAIOSFODNN7EXAMPLE
AWS_SECRET_ACCESS_KEY=wJalrXUtnFEMI/K7MDENG/bPxRfiCYEXAMPLEKEY
AWS_S3_BUCKET_NAME=propease-media

# PhonePe Payment Gateway
# Sandbox base URL: https://api-preprod.phonepe.com/apis/pg-sandbox
# Production base URL: https://api.phonepe.com/apis/hermes
PHONEPE_MERCHANT_ID=YOUR_MERCHANT_ID
PHONEPE_SALT_KEY=YOUR_SALT_KEY
PHONEPE_SALT_INDEX=1
PHONEPE_BASE_URL=https://api-preprod.phonepe.com/apis/pg-sandbox

# OTP / SMS (MSG91)
MSG91_AUTH_KEY=your_msg91_auth_key
MSG91_TEMPLATE_ID=your_template_id
MSG91_SENDER_ID=PRPESE

# GST
GST_RATE=0.18

# Listing config
LISTING_EXPIRY_DAYS=30
PLATFORM_FEE_DAYS=7.5

# Rate limiting
THROTTLE_TTL=60
THROTTLE_LIMIT=100
