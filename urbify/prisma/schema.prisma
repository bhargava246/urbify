generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Listing {
  id        String   @id @default(cuid())
  title     String
  city      String
  locality  String
  rent      Int
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}
